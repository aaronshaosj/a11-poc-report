# ─── Required: Must match Workbench configuration ────────────────────────────
STAFF_JWT_SECRET=your-staff-jwt-secret-here

# ─── Required: Local session token signing key ───────────────────────────────
JWT_SECRET=your-local-jwt-secret-here

# ─── Required: Webhook API key for Workbench communication ───────────────────
WEBHOOK_API_KEY=your-webhook-api-key-here

# ─── Required: Workbench service URL ─────────────────────────────────────────
WORKBENCH_URL=http://120.24.232.253:5000

# ─── Optional: Server port (default 3000) ────────────────────────────────────
PORT=3000

# ─── Optional: Workbench URL for frontend reverse SSO redirect ────────────────
VITE_WORKBENCH_URL=http://120.24.232.253:5000
